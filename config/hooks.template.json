{
  "description": "Native Rust checkpoint guard: preserve root state and recover only empty, weak, or unavailable Codex compactions.",
  "hooks": {
    "PreCompact": [
      {
        "matcher": "auto|manual",
        "hooks": [
          {
            "type": "command",
            "command": "__CODEX_COMPACTION_GUARD_BINARY__",
            "timeout": 15,
            "statusMessage": "Checking compaction checkpoint"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "auto|manual",
        "hooks": [
          {
            "type": "command",
            "command": "__CODEX_COMPACTION_GUARD_BINARY__",
            "timeout": 15,
            "statusMessage": "Checking compacted context"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__CODEX_COMPACTION_GUARD_BINARY__",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "__CODEX_COMPACTION_GUARD_BINARY__",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__CODEX_COMPACTION_GUARD_BINARY__",
            "timeout": 15,
            "statusMessage": "Checking compaction recovery"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__CODEX_COMPACTION_GUARD_BINARY__",
            "timeout": 15,
            "statusMessage": "Checking legacy subagent compaction state"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact|resume",
        "hooks": [
          {
            "type": "command",
            "command": "__CODEX_COMPACTION_GUARD_BINARY__",
            "timeout": 15,
            "statusMessage": "Restoring compacted task state"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__CODEX_COMPACTION_GUARD_BINARY__",
            "timeout": 15,
            "statusMessage": "Checking pending compaction recovery"
          }
        ]
      }
    ]
  }
}
